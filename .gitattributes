# Normalize line endings across platforms.
# CRITICAL: shell scripts must stay LF or bash (incl. Git Bash) breaks on \r.
* text=auto eol=lf

*.sh    text eol=lf
*.bash  text eol=lf
*.js    text eol=lf
*.json  text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.md    text eol=lf
*.toml  text eol=lf
*.py    text eol=lf

# Windows-native scripts stay CRLF.
*.ps1   text eol=crlf
*.bat   text eol=crlf
*.cmd   text eol=crlf

# Common binaries (none yet — safe defaults).
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.pdf   binary
*.sqlite binary
