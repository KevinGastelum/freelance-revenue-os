# .env.example — copy to .env and fill in values.
# Never commit .env — it is git-ignored.
# freelance-os Phase 1 has no required secrets.
# Future phases may use:
#   ANTHROPIC_API_KEY=sk-ant-...   (LLM calls — never auto-submit)
#   GMAIL_CLIENT_ID=               (email alert ingestion — read-only)
#   GMAIL_CLIENT_SECRET=
