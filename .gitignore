# Secrets & environment — never commit (public repo)
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
secrets/
credentials.json
service-account*.json
*.local

# Dependencies
node_modules/
.pnp/
.venv/
venv/
__pycache__/
*.pyc

# Build output
dist/
build/
.next/
out/
coverage/

# Logs
*.log
npm-debug.log*
yarn-error.log*

# OS & editor
.DS_Store
Thumbs.db
*.stackdump
.idea/
.vscode/

# Warren — local runtime artifacts only.
# Keep .warren/{config,triggers,preview}.yaml and .warren/pr-template.md TRACKED.
# (*.log and *.local are already ignored globally above.)
.warren/tmp/

# Claude Code — personal/local overrides (shared .claude/settings.json stays tracked)
# Steering-side material stays local-only so headless Warren sandboxes
# (which clone this repo) never auto-load it.
.claude/settings.local.json
.claude/skills/
.claude/hooks/suggest-handoff.js

# Python project
data/*.sqlite
*.egg-info/
*.egg
.pytest_cache/
client-work/
.agent/
scripts/start_client_session.sh

# --- sandbox/runtime artifacts (Warren dispatches must never commit these) ---
.claude/.credentials.json
.claude/.last-cleanup
.claude/sessions/
.claude/projects/
.claude/backups/
.claude/todos/
.claude.json
.canopy/
.config/
.gitconfig.burrow
.profile
.zshrc
config/presets/
