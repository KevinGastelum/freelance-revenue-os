# Secrets & environment — never commit (public repo)
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
secrets/
credentials.json
service-account*.json
*.local

# Dependencies
node_modules/
.pnp/
.venv/
venv/
__pycache__/
*.pyc

# Build output
dist/
build/
.next/
out/
coverage/

# Logs
*.log
npm-debug.log*
yarn-error.log*

# OS & editor
.DS_Store
Thumbs.db
*.stackdump
.idea/
.vscode/

# Warren — local runtime artifacts only.
# Keep .warren/{config,triggers,preview}.yaml and .warren/pr-template.md TRACKED.
